        if n2 == 14 {"e"} otherwise
        if n2 == 15 {"f"};

        memory = (((substr(memory, 0, 3*p) + n1_s) + n2_s) + " ") + substr(memory, 3*(p + 1), len(memory));
    } otherwise if instr == "-" {
        let byte_s = substr(memory, 3*p, 3*p+2);

        let nibble = substr(byte_s, 0, 1);
        let n1 = if nibble == "0" {0} otherwise
