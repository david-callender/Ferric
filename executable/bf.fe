        if b == "7e" {print("~")};
    } otherwise if instr == "[" {
        let mem = substr(memory, 3*p, 3*p+2);
        if mem == "00" {
            i = i + 1;
            let counter = 1;
            while counter != 0 {
                let b = substr(input, i, i + 1);
                if b == "[" {
                    counter = counter + 1;
                };
                if b == "]" {
                    counter = counter - 1;
                };
                i = i + 1;
            };
            i = i - 1;
        };
    } otherwise if instr == "]" {
        let mem = substr(memory, 3*p, 3*p+2);
        if mem != "00" {
            i = i - 1;
            let counter = -1;
            while counter != 0 {
                let b = substr(input, i, i + 1);
                if b == "[" {
                    counter = counter + 1;
                };
                if b == "]" {
                    counter = counter - 1;
                };
                i = i - 1;
            };
            i = i + 1;
        };
    };
